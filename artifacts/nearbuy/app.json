{
  "expo": {
    "name": "BizIci",
    "slug": "nearbuy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bizici-logo.png",
    "scheme": "bizici",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/bizici-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bizici.app"
    },
    "android": {
      "package": "com.bizici.app"
    },
    "web": {
      "favicon": "./assets/images/bizici-logo.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Autorisez BizIci à accéder à votre caméra pour rechercher des produits par photo."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Autorisez BizIci à utiliser votre position pour vous montrer les boutiques autour de vous."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autorisez BizIci à accéder à vos photos pour la recherche visuelle."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/bizici-logo.png",
          "color": "#F58220",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
