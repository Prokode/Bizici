{
  "expo": {
    "name": "BizIci Pro",
    "slug": "nearbuy-business",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bizici-pin.png",
    "scheme": "bizici-pro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/bizici-pin.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bizici.pro"
    },
    "android": {
      "package": "com.bizici.pro"
    },
    "web": {
      "favicon": "./assets/images/bizici-pin.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Autorisez BizIci Pro à accéder à votre caméra pour prendre des photos de produits."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Autorisez BizIci Pro à utiliser votre position pour définir l'emplacement précis de votre boutique."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autorisez BizIci Pro à accéder à vos photos pour sélectionner des images de produits."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/bizici-pin.png",
          "color": "#F58220",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
